# Variables para el frontend (expuestas al browser, usar solo anon key)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Variable para scripts de Node (NUNCA exponer en el frontend)
# Ir a Supabase → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
